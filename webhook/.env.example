# Neon Webhook — Environment Variables
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env no repositório!

# ─── Session Keys ──────────────────────────────────────────────────
# Sessões internas dedicadas do webhook para cada agente.
# Criadas automaticamente no primeiro uso.
# Exemplo: agent:main:webhook-neon

# Neon (Iago)
NEON_SESSION_KEY=***

# Emily (Jéssica)
EMILY_SESSION_KEY=***

# Oliver (Dev)
OLIVER_SESSION_KEY=***

# ─── Servidor ──────────────────────────────────────────────────────
WEBHOOK_PORT=3344
WEBHOOK_HOST=0.0.0.0

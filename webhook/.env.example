# Neon Webhook — Environment Variables
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env no repositório!

# ─── Session Key ────────────────────────────────────────────────────
# Sessão interna dedicada do webhook, sem vinculação com Telegram.
# O webhook usa uma única sessão para todos os agentes.
# Exemplo: agent:main:webhook-internal

WEBHOOK_SESSION_KEY=***

# ─── Servidor ──────────────────────────────────────────────────────
WEBHOOK_PORT=3344
WEBHOOK_HOST=0.0.0.0

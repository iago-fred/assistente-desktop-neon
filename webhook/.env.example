# Neon Webhook — Environment Variables
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env no repositório!

# ─── Session Keys ──────────────────────────────────────────────────
# São identificadores internos de sessão dos agentes no OpenClaw.
# Para agentes comuns: agent:<agent-name>:main
# Para Oliver: agent:main:oliver

# Neon (Iago)
NEON_SESSION_KEY=agent:main:main

# Emily (Jéssica)
EMILY_SESSION_KEY=agent:emily:main

# Oliver (Dev)
OLIVER_SESSION_KEY=agent:main:oliver

# ─── Servidor ──────────────────────────────────────────────────────
WEBHOOK_PORT=3344
WEBHOOK_HOST=0.0.0.0
